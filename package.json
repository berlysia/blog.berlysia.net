    "fix:prettier": "yarn lint:prettier --write",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "11.0.1",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "devDependencies": {
    "@berlysia/eslint-config": "^2.1.3",
    "@types/react": "17.0.14",
    "eslint": "7.31.0",
    "eslint-config-next": "11.0.1",
    "husky": "^7.0.1",
    "lint-staged": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.3.2",
    "typescript": "4.3.5"
  }
}
