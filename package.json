{
  "name": "blog.berlysia.net",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint '**/*.{js,ts,jsx,tsx}'",
